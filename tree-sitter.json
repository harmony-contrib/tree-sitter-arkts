{
  "grammars": [
    {
      "name": "arkts",
      "camelcase": "ArkTS",
      "scope": "source.ets",
      "path": ".",
      "external-files": [
        "common/scanner.h"
      ],
      "file-types": [
        "ets"
      ],
      "highlights": [
        "queries/highlights.scm",
        "node_modules/tree-sitter-javascript/queries/highlights.scm"
      ],
      "injections": "node_modules/tree-sitter-javascript/queries/injections.scm",
      "locals": [
        "queries/locals.scm",
        "node_modules/tree-sitter-javascript/queries/locals.scm"
      ],
      "tags": [
        "queries/tags.scm",
        "node_modules/tree-sitter-javascript/queries/tags.scm"
      ],
      "injection-regex": "^(ets|arkts)$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "ArkTS grammar for tree-sitter",
    "authors": [
      {
        "name": "richerfu",
        "email": "southorange0929@foxmail.com"
      },
      {
        "name": "Max Brunsfeld",
        "email": "maxbrunsfeld@gmail.com"
      },
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/harmony-contrib/tree-sitter-arkts"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
